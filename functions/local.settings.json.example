{
  "IsEncrypted": false,
  "Values": {
    "AzureWebJobsStorage": "UseDevelopmentStorage=true",
    "FUNCTIONS_WORKER_RUNTIME": "python",
    "PYTHON_VERSION": "3.11",

    "USE_MANAGED_IDENTITY": "false",
    "AZURE_TENANT_ID": "<your-tenant-id>",
    "AZURE_CLIENT_ID": "<your-app-registration-client-id>",
    "AZURE_CLIENT_SECRET": "<your-app-registration-client-secret>",

    "LOG_ANALYTICS_DCE": "https://<your-dce>.uksouth-1.ingest.monitor.azure.com",
    "LOG_ANALYTICS_DCR_ID": "dcr-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx",

    "LOG_ANALYTICS_WORKSPACE_ID": "<your-workspace-guid>",
    "ALERT_SENDER_ADDRESS": "<shared-mailbox-or-service-account>@yourdomain.com",
    "ALERT_RECIPIENTS": "it-admins@yourdomain.com"
  }
}
