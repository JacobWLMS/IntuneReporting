        "uri": "https://files.pythonhosted.org/packages/25/c5/0ee2d87ac83c73cf64c5f5e5e58f61697f1a41dca0b6eb6eabdc438e4cd5/azure_kusto_data-4.6.1-py2.py3-none-any.whl"
