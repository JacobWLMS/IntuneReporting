      }
    },
    "tenantId": {
      "type": "string",
      "defaultValue": "[subscription().tenantId]",
      "metadata": {
        "description": "Azure AD Tenant ID"
      }
    },
    "graphClientId": {
      "type": "string",
      "defaultValue": "",
      "metadata": {
        "description": "App Registration Client ID for Microsoft Graph API"
      }
    },
    "graphClientSecret": {
      "type": "securestring",
      "defaultValue": "",
      "metadata": {
        "description": "App Registration Client Secret for Microsoft Graph API"
      }
    },
    "adxClusterUri": {
      "type": "string",
      "defaultValue": "",
      "metadata": {
        "description": "Azure Data Explorer cluster URI (e.g., https://mycluster.region.kusto.windows.net)"
      }
    },
    "adxDatabaseName": {
      "type": "string",
      "defaultValue": "IntuneAnalytics",
