        "name": "runbooks",
        "count": "[length(variables('runbookConfigs'))]"
      },
      "type": "Microsoft.Automation/automationAccounts/runbooks",
      "apiVersion": "2023-11-01",
      "name": "[format('{0}/{1}', variables('automationAccountName'), variables('runbookConfigs')[copyIndex()].name)]",
      "location": "[parameters('location')]",
      "properties": {
        "runbookType": "Python3",
        "logProgress": true,
        "logVerbose": true,
        "description": "[variables('runbookConfigs')[copyIndex()].desc]",
        "publishContentLink": {
          "uri": "[variables('runbookConfigs')[copyIndex()].url]"
        }
      },
      "dependsOn": [
        "[resourceId('Microsoft.Automation/automationAccounts', variables('automationAccountName'))]",
        "corePackages"
      ]
    },
    {
      "copy": {
        "name": "schedules",
        "count": "[length(variables('runbookConfigs'))]"
      },
      "type": "Microsoft.Automation/automationAccounts/schedules",
      "apiVersion": "2023-11-01",
      "name": "[format('{0}/{1}', variables('automationAccountName'), variables('runbookConfigs')[copyIndex()].scheduleName)]",
      "properties": {
        "frequency": "[variables('runbookConfigs')[copyIndex()].freq]",
        "interval": "[variables('runbookConfigs')[copyIndex()].interval]",
        "startTime": "[parameters('scheduleStartTime')]",
        "timeZone": "UTC"
      },
      "dependsOn": [
        "[resourceId('Microsoft.Automation/automationAccounts', variables('automationAccountName'))]"
      ]
    },
    {
      "copy": {
        "name": "jobSchedules",
        "count": "[length(variables('runbookConfigs'))]"
      },
      "type": "Microsoft.Automation/automationAccounts/jobSchedules",
      "apiVersion": "2023-11-01",
      "name": "[format('{0}/{1}', variables('automationAccountName'), guid(resourceId('Microsoft.Automation/automationAccounts', variables('automationAccountName')), variables('runbookConfigs')[copyIndex()].name, variables('runbookConfigs')[copyIndex()].scheduleName))]",
      "properties": {
        "runbook": {
          "name": "[variables('runbookConfigs')[copyIndex()].name]"
        },
        "schedule": {
          "name": "[variables('runbookConfigs')[copyIndex()].scheduleName]"
        }
      },
      "dependsOn": [
        "[resourceId('Microsoft.Automation/automationAccounts', variables('automationAccountName'))]",
        "[resourceId('Microsoft.Automation/automationAccounts/runbooks', variables('automationAccountName'), variables('runbookConfigs')[copyIndex()].name)]",
        "[resourceId('Microsoft.Automation/automationAccounts/schedules', variables('automationAccountName'), variables('runbookConfigs')[copyIndex()].scheduleName)]"
      ]
