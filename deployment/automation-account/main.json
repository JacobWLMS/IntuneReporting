      "properties": {
        "value": "[format('\"{0}\"', parameters('tenantId'))]",
        "isEncrypted": false,
        "description": "Azure AD Tenant ID"
      },
      "dependsOn": [
        "[resourceId('Microsoft.Automation/automationAccounts', variables('automationAccountName'))]"
      ]
    },
    {
      "type": "Microsoft.Automation/automationAccounts/variables",
      "apiVersion": "2023-11-01",
      "name": "[format('{0}/{1}', variables('automationAccountName'), 'AZURE_CLIENT_ID')]",
      "properties": {
        "value": "[format('\"{0}\"', parameters('graphClientId'))]",
        "isEncrypted": false,
        "description": "App Registration Client ID for Microsoft Graph"
      },
      "dependsOn": [
        "[resourceId('Microsoft.Automation/automationAccounts', variables('automationAccountName'))]"
      ]
    },
    {
      "type": "Microsoft.Automation/automationAccounts/variables",
      "apiVersion": "2023-11-01",
      "name": "[format('{0}/{1}', variables('automationAccountName'), 'AZURE_CLIENT_SECRET')]",
      "properties": {
        "value": "[format('\"{0}\"', parameters('graphClientSecret'))]",
        "isEncrypted": true,
        "description": "App Registration Client Secret for Microsoft Graph"
      },
      "dependsOn": [
        "[resourceId('Microsoft.Automation/automationAccounts', variables('automationAccountName'))]"
      ]
    },
    {
      "type": "Microsoft.Automation/automationAccounts/variables",
      "apiVersion": "2023-11-01",
      "name": "[format('{0}/{1}', variables('automationAccountName'), 'ANALYTICS_BACKEND')]",
      "properties": {
        "value": "[format('\"{0}\"', parameters('analyticsBackend'))]",
        "isEncrypted": false,
        "description": "Analytics backend: ADX or LogAnalytics"
      },
      "dependsOn": [
        "[resourceId('Microsoft.Automation/automationAccounts', variables('automationAccountName'))]"
      ]
    },
    {
      "condition": "[equals(parameters('analyticsBackend'), 'ADX')]",
      "type": "Microsoft.Automation/automationAccounts/variables",
      "apiVersion": "2023-11-01",
      "name": "[format('{0}/{1}', variables('automationAccountName'), 'ADX_CLUSTER_URI')]",
      "properties": {
        "value": "[format('\"{0}\"', parameters('adxClusterUri'))]",
        "isEncrypted": false,
        "description": "Azure Data Explorer cluster URI"
      },
      "dependsOn": [
        "[resourceId('Microsoft.Automation/automationAccounts', variables('automationAccountName'))]"
      ]
    },
    {
      "condition": "[equals(parameters('analyticsBackend'), 'ADX')]",
      "type": "Microsoft.Automation/automationAccounts/variables",
      "apiVersion": "2023-11-01",
      "name": "[format('{0}/{1}', variables('automationAccountName'), 'ADX_DATABASE')]",
      "properties": {
        "value": "[format('\"{0}\"', parameters('adxDatabaseName'))]",
        "isEncrypted": false,
        "description": "Azure Data Explorer database name"
      },
      "dependsOn": [
        "[resourceId('Microsoft.Automation/automationAccounts', variables('automationAccountName'))]"
      ]
    },
    {
      "condition": "[equals(parameters('analyticsBackend'), 'LogAnalytics')]",
      "type": "Microsoft.Automation/automationAccounts/variables",
      "apiVersion": "2023-11-01",
      "name": "[format('{0}/{1}', variables('automationAccountName'), 'LOG_ANALYTICS_DCE')]",
      "properties": {
        "value": "[format('\"{0}\"', parameters('logAnalyticsDce'))]",
        "isEncrypted": false,
        "description": "Log Analytics Data Collection Endpoint"
      },
      "dependsOn": [
        "[resourceId('Microsoft.Automation/automationAccounts', variables('automationAccountName'))]"
      ]
    },
    {
      "condition": "[equals(parameters('analyticsBackend'), 'LogAnalytics')]",
      "type": "Microsoft.Automation/automationAccounts/variables",
      "apiVersion": "2023-11-01",
      "name": "[format('{0}/{1}', variables('automationAccountName'), 'LOG_ANALYTICS_DCR_ID')]",
      "properties": {
        "value": "[format('\"{0}\"', parameters('logAnalyticsDcrId'))]",
        "isEncrypted": false,
        "description": "Log Analytics Data Collection Rule ID"
      },
      "dependsOn": [
