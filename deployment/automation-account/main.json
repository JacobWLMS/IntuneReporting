  "resources": [
    {
      "type": "Microsoft.Automation/automationAccounts",
      "apiVersion": "2023-11-01",
      "name": "[variables('automationAccountName')]",
      "location": "[parameters('location')]",
      "identity": {
        "type": "SystemAssigned"
      },
      "properties": {
        "sku": {
          "name": "Basic"
        },
        "publicNetworkAccess": true
      }
    },
    {
      "copy": {
        "name": "corePackages",
        "count": "[length(variables('pythonPackages'))]",
        "mode": "serial",
        "batchSize": 1
      },
      "type": "Microsoft.Automation/automationAccounts/python3Packages",
      "apiVersion": "2023-11-01",
      "name": "[format('{0}/{1}', variables('automationAccountName'), variables('pythonPackages')[copyIndex()].name)]",
      "properties": {
        "contentLink": {
          "uri": "[variables('pythonPackages')[copyIndex()].uri]"
        }
      },
      "dependsOn": [
        "[resourceId('Microsoft.Automation/automationAccounts', variables('automationAccountName'))]"
      ]
    },
    {
      "copy": {
        "name": "adxPkgs",
        "count": "[length(variables('adxPackages'))]",
        "mode": "serial",
        "batchSize": 1
      },
      "condition": "[equals(parameters('analyticsBackend'), 'ADX')]",
      "type": "Microsoft.Automation/automationAccounts/python3Packages",
      "apiVersion": "2023-11-01",
      "name": "[format('{0}/{1}', variables('automationAccountName'), variables('adxPackages')[copyIndex()].name)]",
      "properties": {
        "contentLink": {
          "uri": "[variables('adxPackages')[copyIndex()].uri]"
        }
      },
      "dependsOn": [
        "[resourceId('Microsoft.Automation/automationAccounts', variables('automationAccountName'))]",
        "corePackages"
      ]
    },
    {
      "copy": {
        "name": "logAnalyticsPkgs",
        "count": "[length(variables('logAnalyticsPackages'))]",
        "mode": "serial",
        "batchSize": 1
      },
      "condition": "[equals(parameters('analyticsBackend'), 'LogAnalytics')]",
      "type": "Microsoft.Automation/automationAccounts/python3Packages",
      "apiVersion": "2023-11-01",
      "name": "[format('{0}/{1}', variables('automationAccountName'), variables('logAnalyticsPackages')[copyIndex()].name)]",
      "properties": {
        "contentLink": {
          "uri": "[variables('logAnalyticsPackages')[copyIndex()].uri]"
        }
      },
      "dependsOn": [
