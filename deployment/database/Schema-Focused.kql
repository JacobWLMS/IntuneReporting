// =============================================================================
// INTUNE ANALYTICS - ADX SCHEMA
// =============================================================================
// Architecture: Raw tables (short retention) + Materialized Views (current state)
// This solves the "duplicate data" problem - always query *_Current views!
// =============================================================================

// -----------------------------------------------------------------------------
// MANAGED DEVICES: Core inventory table (everything links to this)
// Runbook: export_devices.py | Schedule: Every 4 hours
// -----------------------------------------------------------------------------

.create table ManagedDevices (
    DeviceId: string,
    DeviceName: string,
    UserPrincipalName: string,
    UserDisplayName: string,
    OperatingSystem: string,
    OSVersion: string,
    ComplianceState: string,
    ManagementState: string,
    EnrolledDateTime: datetime,
    LastSyncDateTime: datetime,
    Manufacturer: string,
    Model: string,
    SerialNumber: string,
    IMEI: string,
    ManagementAgent: string,
    OwnerType: string,
    DeviceEnrollmentType: string,
    EmailAddress: string,
    AzureADRegistered: bool,
    AzureADDeviceId: string,
    DeviceRegistrationState: string,
    IsEncrypted: bool,
    IsSupervised: bool,
    JailBroken: string,
    AutopilotEnrolled: bool,
    DeviceCategory: string,
    TotalStorageGB: real,
    FreeStorageGB: real,
    PhysicalMemoryGB: real,
    WiFiMacAddress: string,
    EthernetMacAddress: string,
    TimeGenerated: datetime,
    IngestionTime: datetime,
    SourceSystem: string
)

.alter table ManagedDevices policy retention 
```
{ "SoftDeletePeriod": "7.00:00:00", "Recoverability": "Disabled" }
```

.create materialized-view ManagedDevices_Current on table ManagedDevices {
    ManagedDevices
    | summarize arg_max(IngestionTime, *) by DeviceId
}


// -----------------------------------------------------------------------------
// COMPLIANCE POLICIES: Policy definitions
// Runbook: export_compliance.py | Schedule: Every 6 hours
// -----------------------------------------------------------------------------

.create table CompliancePolicies (
    PolicyId: string,
    PolicyName: string,
    Description: string,
    CreatedDateTime: datetime,
    LastModifiedDateTime: datetime,
    PolicyType: string,
    TimeGenerated: datetime,
    IngestionTime: datetime,
    SourceSystem: string
)

.alter table CompliancePolicies policy retention 
```
{ "SoftDeletePeriod": "7.00:00:00", "Recoverability": "Disabled" }
```

.create materialized-view CompliancePolicies_Current on table CompliancePolicies {
    CompliancePolicies
    | summarize arg_max(IngestionTime, *) by PolicyId
}


// -----------------------------------------------------------------------------
// DEVICE COMPLIANCE STATES: Per-device per-policy compliance status
// Runbook: export_compliance.py | Schedule: Every 6 hours
// -----------------------------------------------------------------------------

.create table DeviceComplianceStates (
    DeviceId: string,
    DeviceName: string,
    UserId: string,
    UserPrincipalName: string,
    PolicyId: string,
    PolicyName: string,
    Status: string,
    StatusRaw: int,
    SettingCount: int,
    FailedSettingCount: int,
    LastContact: datetime,
    InGracePeriodCount: int,
    TimeGenerated: datetime,
    IngestionTime: datetime,
    SourceSystem: string
)

.alter table DeviceComplianceStates policy retention 
```
{ "SoftDeletePeriod": "7.00:00:00", "Recoverability": "Disabled" }
```

.create materialized-view DeviceComplianceStates_Current on table DeviceComplianceStates {
    DeviceComplianceStates
    | summarize arg_max(IngestionTime, *) by DeviceId, PolicyId
}


// -----------------------------------------------------------------------------
// DEVICE SCORES: Endpoint Analytics health scores
// Runbook: export_endpoint_analytics.py | Schedule: Daily 8 AM UTC
// -----------------------------------------------------------------------------

.create table DeviceScores (
    DeviceId: string,
    DeviceName: string,
    Model: string,
    Manufacturer: string,
    HealthStatus: string,
    EndpointAnalyticsScore: real,
    StartupPerformanceScore: real,
    AppReliabilityScore: real,
    WorkFromAnywhereScore: real,
    MeanResourceSpikeTimeScore: real,
    BatteryHealthScore: real,
    TimeGenerated: datetime,
    IngestionTime: datetime,
    SourceSystem: string
)

.alter table DeviceScores policy retention 
```
{ "SoftDeletePeriod": "7.00:00:00", "Recoverability": "Disabled" }
```

.create materialized-view DeviceScores_Current on table DeviceScores {
    DeviceScores
    | summarize arg_max(IngestionTime, *) by DeviceId
}


// -----------------------------------------------------------------------------
// STARTUP PERFORMANCE: Boot and login timing history
// Runbook: export_endpoint_analytics.py | Schedule: Daily 8 AM UTC
// Note: Longer retention for trend analysis
// -----------------------------------------------------------------------------

.create table StartupPerformance (
    DeviceId: string,
    StartTime: datetime,
    CoreBootTimeInMs: int,
    GroupPolicyBootTimeInMs: int,
    GroupPolicyLoginTimeInMs: int,
    CoreLoginTimeInMs: int,
    TotalBootTimeInMs: int,
    TotalLoginTimeInMs: int,
    IsFirstLogin: bool,
    IsFeatureUpdate: bool,
    OperatingSystemVersion: string,
    RestartCategory: string,
    RestartFaultBucket: string,
    TimeGenerated: datetime,
    IngestionTime: datetime,
    SourceSystem: string
)

.alter table StartupPerformance policy retention 
```
{ "SoftDeletePeriod": "30.00:00:00", "Recoverability": "Disabled" }
```


// -----------------------------------------------------------------------------
// APP RELIABILITY: Application crash and hang metrics
// Runbook: export_endpoint_analytics.py | Schedule: Daily 8 AM UTC
// -----------------------------------------------------------------------------

.create table AppReliability (
    AppName: string,
    AppDisplayName: string,
    AppPublisher: string,
    ActiveDeviceCount: int,
    AppCrashCount: int,
    AppHangCount: int,
    MeanTimeToFailureInMinutes: int,
    AppHealthScore: real,
    AppHealthStatus: string,
    TimeGenerated: datetime,
    IngestionTime: datetime,
    SourceSystem: string
)

.alter table AppReliability policy retention 
```
{ "SoftDeletePeriod": "7.00:00:00", "Recoverability": "Disabled" }
```

.create materialized-view AppReliability_Current on table AppReliability {
    AppReliability
    | summarize arg_max(IngestionTime, *) by AppName
}


