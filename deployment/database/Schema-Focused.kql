// -----------------------------------------------------------------------------
// SYNC STATE: Export tracking and audit log
// All runbooks write to this
// -----------------------------------------------------------------------------

.create table SyncState (
    SyncType: string,
    RecordCount: int,
    PolicyCount: int,
    StateCount: int,
    Status: string,
    DurationSeconds: real,
    SyncTime: datetime,
    TimeGenerated: datetime,
    IngestionTime: datetime,
    SourceSystem: string
)


// =============================================================================
// FUNCTIONS: Pre-built queries for dashboards and alerts
// =============================================================================

// -----------------------------------------------------------------------------
// COMPLIANCE FUNCTIONS
// -----------------------------------------------------------------------------

// Get all non-compliant devices with full details
.create-or-alter function NonCompliantDevices() {
    DeviceComplianceStates_Current
    | where Status == "noncompliant"
    | join kind=leftouter ManagedDevices_Current on DeviceId
    | project 
        DeviceId,
        DeviceName,
        UserPrincipalName,
        UserDisplayName,
        PolicyName,
        FailedSettingCount,
        LastContact,
        OperatingSystem,
        OSVersion,
        Manufacturer,
        Model,
        LastSyncDateTime
    | order by FailedSettingCount desc
}

// Compliance summary by policy
.create-or-alter function ComplianceSummaryByPolicy() {
    DeviceComplianceStates_Current
    | summarize 
        Compliant = countif(Status == "compliant"),
        NonCompliant = countif(Status == "noncompliant"),
        InGracePeriod = countif(Status == "inGracePeriod"),
        Unknown = countif(Status == "unknown"),
        Total = count()
        by PolicyId, PolicyName
    | extend ComplianceRate = round(100.0 * Compliant / Total, 1)
    | order by ComplianceRate asc
}

// Overall compliance rate
.create-or-alter function ComplianceOverview() {
    ManagedDevices_Current
    | summarize 
        Compliant = countif(ComplianceState == "compliant"),
        NonCompliant = countif(ComplianceState == "noncompliant"),
        InGracePeriod = countif(ComplianceState == "inGracePeriod"),
        Unknown = countif(ComplianceState == "unknown" or isempty(ComplianceState)),
        Total = count()
    | extend ComplianceRate = round(100.0 * Compliant / Total, 1)
}


// -----------------------------------------------------------------------------
// DEVICE INVENTORY FUNCTIONS
// -----------------------------------------------------------------------------

// Device inventory summary by OS
.create-or-alter function DevicesByOS() {
    ManagedDevices_Current
    | summarize Count = count() by OperatingSystem
    | order by Count desc
}

// Device inventory summary by manufacturer/model
.create-or-alter function DevicesByHardware() {
    ManagedDevices_Current
    | summarize Count = count() by Manufacturer, Model
    | order by Count desc
}

// Stale devices (not synced in X days)
.create-or-alter function StaleDevices(staleDays: int = 14) {
    ManagedDevices_Current
    | where LastSyncDateTime < ago(staleDays * 1d)
    | project 
        DeviceId,
        DeviceName,
        UserPrincipalName,
        LastSyncDateTime,
        DaysSinceSync = datetime_diff('day', now(), LastSyncDateTime),
        OperatingSystem,
        Model
    | order by DaysSinceSync desc
}

// Unencrypted devices
.create-or-alter function UnencryptedDevices() {
    ManagedDevices_Current
    | where IsEncrypted == false
    | project 
        DeviceId,
        DeviceName,
        UserPrincipalName,
        OperatingSystem,
        OSVersion,
        Manufacturer,
        Model
}


// -----------------------------------------------------------------------------
// ENDPOINT ANALYTICS FUNCTIONS
// -----------------------------------------------------------------------------

// Devices with poor health scores
.create-or-alter function PoorHealthDevices(threshold: real = 50.0) {
    DeviceScores_Current
    | where EndpointAnalyticsScore < threshold
    | join kind=leftouter ManagedDevices_Current on DeviceId
    | project 
        DeviceId,
        DeviceName,
        UserPrincipalName,
        EndpointAnalyticsScore,
        StartupPerformanceScore,
        AppReliabilityScore,
        HealthStatus,
        OperatingSystem,
        Model
    | order by EndpointAnalyticsScore asc
}

// Slow boot devices
.create-or-alter function SlowBootDevices(thresholdMs: int = 60000) {
    StartupPerformance
    | where StartTime > ago(7d)
    | summarize 
        AvgBootTime = avg(TotalBootTimeInMs),
        MaxBootTime = max(TotalBootTimeInMs),
        BootCount = count()
        by DeviceId
    | where AvgBootTime > thresholdMs
    | join kind=leftouter ManagedDevices_Current on DeviceId
    | project 
        DeviceId,
        DeviceName,
        UserPrincipalName,
        AvgBootTimeSeconds = round(AvgBootTime / 1000, 1),
        MaxBootTimeSeconds = round(MaxBootTime / 1000, 1),
        BootCount,
        Model
    | order by AvgBootTimeSeconds desc
}

// Problematic apps
.create-or-alter function ProblematicApps(minCrashes: int = 10) {
    AppReliability_Current
    | where AppCrashCount >= minCrashes or AppHangCount >= minCrashes
    | project 
        AppName,
        AppDisplayName,
        AppPublisher,
        ActiveDeviceCount,
        AppCrashCount,
        AppHangCount,
        TotalIssues = AppCrashCount + AppHangCount,
        AppHealthScore,
        AppHealthStatus
    | order by TotalIssues desc
}


// -----------------------------------------------------------------------------
// AUTOPILOT FUNCTIONS
// -----------------------------------------------------------------------------

// Autopilot devices pending enrollment
.create-or-alter function AutopilotPendingEnrollment() {
    AutopilotDevices_Current
    | where EnrollmentState in ("notContacted", "notRegistered", "pendingReset")
    | project 
        AutopilotDeviceId,
        SerialNumber,
        Manufacturer,
        Model,
        GroupTag,
        EnrollmentState,
        LastContactedDateTime,
        DeploymentProfileAssignmentStatus
    | order by LastContactedDateTime asc
}

// Autopilot enrollment failures
.create-or-alter function AutopilotEnrollmentFailures() {
    AutopilotDevices_Current
    | where EnrollmentState == "failed" or EnrollmentState == "blocked"
    | project 
        AutopilotDeviceId,
        SerialNumber,
        Manufacturer,
        Model,
        GroupTag,
        EnrollmentState,
        RemediationState,
        LastContactedDateTime
}

// Autopilot summary by group tag
.create-or-alter function AutopilotSummaryByGroupTag() {
    AutopilotDevices_Current
    | summarize 
        Enrolled = countif(EnrollmentState == "enrolled"),
        Pending = countif(EnrollmentState in ("notContacted", "notRegistered", "pendingReset")),
        Failed = countif(EnrollmentState == "failed"),
        Total = count()
        by GroupTag
    | extend EnrollmentRate = round(100.0 * Enrolled / Total, 1)
    | order by Total desc
}


// -----------------------------------------------------------------------------
// ALERT FUNCTIONS (for scheduled queries / Logic Apps)
// -----------------------------------------------------------------------------

// Alert: New non-compliant devices in last N hours
.create-or-alter function AlertNewNonCompliant(hoursBack: int = 6) {
    DeviceComplianceStates_Current
    | where Status == "noncompliant"
    | where IngestionTime > ago(hoursBack * 1h)
    | join kind=leftouter ManagedDevices_Current on DeviceId
    | project 
        DeviceId,
        DeviceName,
        UserPrincipalName,
        PolicyName,
        FailedSettingCount,
        DetectedTime = IngestionTime
}

// Alert: Devices not synced in X days
.create-or-alter function AlertStaleDevices(staleDays: int = 7) {
    ManagedDevices_Current
    | where LastSyncDateTime < ago(staleDays * 1d)
    | where IngestionTime > ago(1d)  // Only alert on recently seen devices
    | project 
        DeviceId,
        DeviceName,
        UserPrincipalName,
        LastSyncDateTime,
        DaysSinceSync = datetime_diff('day', now(), LastSyncDateTime)
}

// Alert: Health score drops
.create-or-alter function AlertHealthScoreDrop(dropThreshold: real = 20.0) {
    DeviceScores
    | where IngestionTime > ago(2d)
    | summarize arg_max(IngestionTime, *), arg_min(IngestionTime, PreviousScore=EndpointAnalyticsScore) by DeviceId
    | where EndpointAnalyticsScore < PreviousScore - dropThreshold
    | project 
        DeviceId,
        DeviceName,
        CurrentScore = EndpointAnalyticsScore,
        PreviousScore,
        ScoreDrop = PreviousScore - EndpointAnalyticsScore
}

// Alert: Autopilot enrollment failures
.create-or-alter function AlertAutopilotFailures() {
    AutopilotDevices_Current
    | where EnrollmentState in ("failed", "blocked")
    | where IngestionTime > ago(1d)
    | project 
        AutopilotDeviceId,
        SerialNumber,
        Manufacturer,
        Model,
        GroupTag,
        EnrollmentState,
        RemediationState,
        LastContactedDateTime
}
