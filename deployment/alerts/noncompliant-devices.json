{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
  "contentVersion": "1.0.0.0",
  "parameters": {
    "workspaceResourceId": {
      "type": "string",
      "metadata": {
        "description": "Full resource ID of Log Analytics workspace (e.g., /subscriptions/.../resourceGroups/.../providers/Microsoft.OperationalInsights/workspaces/...)"
      }
    },
    "actionGroupId": {
      "type": "string",
      "defaultValue": "",
      "metadata": {
        "description": "Optional: Resource ID of Action Group for notifications. Leave empty to create alert without notifications."
      }
    },
    "threshold": {
      "type": "int",
      "defaultValue": 10,
      "metadata": {
        "description": "Alert when non-compliant device count exceeds this threshold"
      }
    },
    "location": {
      "type": "string",
      "defaultValue": "[resourceGroup().location]"
    }
  },
  "variables": {
    "alertName": "Intune - Non-Compliant Devices Threshold",
    "alertDescription": "Alerts when the number of non-compliant devices exceeds the configured threshold. Review compliance policies and device status in the Intune portal."
  },
  "resources": [
    {
      "type": "Microsoft.Insights/scheduledQueryRules",
      "apiVersion": "2023-03-15-preview",
      "name": "[variables('alertName')]",
      "location": "[parameters('location')]",
      "properties": {
        "displayName": "[variables('alertName')]",
        "description": "[variables('alertDescription')]",
        "severity": 2,
        "enabled": true,
        "evaluationFrequency": "PT1H",
        "scopes": ["[parameters('workspaceResourceId')]"],
        "windowSize": "PT1H",
        "criteria": {
          "allOf": [
            {
              "query": "IntuneManagedDevices_CL\n| summarize arg_max(TimeGenerated, *) by DeviceId\n| where ComplianceState == 'noncompliant'\n| summarize NonCompliantCount = count()\n| where NonCompliantCount > 0",
              "timeAggregation": "Count",
              "dimensions": [],
              "operator": "GreaterThan",
              "threshold": "[parameters('threshold')]",
              "failingPeriods": {
                "numberOfEvaluationPeriods": 1,
                "minFailingPeriodsToAlert": 1
              }
            }
          ]
        },
        "autoMitigate": true,
        "actions": {
          "actionGroups": "[if(empty(parameters('actionGroupId')), json('[]'), array(parameters('actionGroupId')))]"
        }
      }
    }
  ],
  "outputs": {
    "alertId": {
      "type": "string",
      "value": "[resourceId('Microsoft.Insights/scheduledQueryRules', variables('alertName'))]"
    }
  }
}
