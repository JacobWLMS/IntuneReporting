          {
            "type": 9,
            "content": {
              "version": "KqlParameterItem/1.0",
              "parameters": [
                {
                  "id": "device-search",
                  "version": "KqlParameterItem/1.0",
                  "name": "DeviceSearch",
                  "type": 1,
                  "label": "Search Device Name",
                  "value": "a-"
                }
              ],
              "style": "above",
              "queryType": 0,
              "resourceType": "microsoft.operationalinsights/workspaces"
            },
            "name": "inventory-search"
          },
          {
            "type": 3,
            "content": {
              "version": "KqlItem/1.0",
              "query": "IntuneDevices_CL\r\n| where TimeGenerated {TimeRange}\r\n| summarize arg_max(TimeGenerated, *) by DeviceId\r\n| where '*' in ({OSFilter}) or OperatingSystem in ({OSFilter})\r\n| where '*' in ({ComplianceFilter}) or ComplianceState in ({ComplianceFilter})\r\n| where '*' in ({ManufacturerFilter}) or Manufacturer in ({ManufacturerFilter})\r\n| where isempty('{DeviceSearch}') or DeviceName contains '{DeviceSearch}'\r\n| project \r\n    DeviceName,\r\n    User = UserDisplayName,\r\n    OS = OperatingSystem,\r\n    ['OS Version'] = OSVersion,\r\n    Manufacturer,\r\n    Model,\r\n    ComplianceState,\r\n    IsEncrypted,\r\n    OwnerType,\r\n    ['Total GB'] = round(TotalStorageGB, 1),\r\n    ['Free GB'] = round(FreeStorageGB, 1),\r\n    ['Last Sync'] = LastSyncDateTime,\r\n    ['Enrolled'] = EnrolledDateTime,\r\n    DeviceId\r\n| order by DeviceName asc",
              "size": 0,
              "title": "Complete Device Inventory",
              "showExportToExcel": true,
              "queryType": 0,
              "resourceType": "microsoft.operationalinsights/workspaces",
              "visualization": "table",
              "gridSettings": {
                "formatters": [
                  {
                    "columnMatch": "ComplianceState",
                    "formatter": 18,
                    "formatOptions": {
                      "thresholdsOptions": "icons",
                      "thresholdsGrid": [
                        {
                          "operator": "==",
                          "thresholdValue": "compliant",
                          "representation": "success",
                          "text": "{0}"
                        },
                        {
                          "operator": "==",
                          "thresholdValue": "noncompliant",
                          "representation": "failed",
                          "text": "{0}"
                        },
                        {
                          "operator": "==",
                          "thresholdValue": "inGracePeriod",
                          "representation": "pending",
                          "text": "{0}"
                        },
                        {
                          "operator": "Default",
                          "representation": "unknown",
                          "text": "{0}"
                        }
                      ]
                    }
                  },
                  {
                    "columnMatch": "IsEncrypted",
                    "formatter": 18,
                    "formatOptions": {
                      "thresholdsOptions": "icons",
                      "thresholdsGrid": [
                        {
                          "operator": "==",
                          "thresholdValue": "true",
                          "representation": "success",
                          "text": "Yes"
                        },
                        {
                          "operator": "==",
                          "thresholdValue": "false",
                          "representation": "failed",
                          "text": "No"
                        },
                        {
                          "operator": "Default",
                          "representation": "unknown",
                          "text": "{0}"
                        }
                      ]
                    }
                  },
                  {
                    "columnMatch": "OwnerType",
                    "formatter": 18,
                    "formatOptions": {
                      "thresholdsOptions": "icons",
                      "thresholdsGrid": [
                        {
                          "operator": "==",
                          "thresholdValue": "company",
                          "representation": "1",
                          "text": "Corporate"
                        },
                        {
                          "operator": "==",
                          "thresholdValue": "personal",
                          "representation": "2",
                          "text": "Personal"
                        },
                        {
                          "operator": "Default",
                          "representation": "unknown",
                          "text": "{0}"
                        }
                      ]
                    }
                  },
                  {
                    "columnMatch": "Last Sync",
                    "formatter": 6
                  },
                  {
                    "columnMatch": "Enrolled",
                    "formatter": 6
                  },
                  {
                    "columnMatch": "DeviceId",
                    "formatter": 5
                  }
                ],
                "filter": true,
                "sortBy": [
                  {
                    "itemKey": "DeviceName",
                    "sortOrder": 1
                  }
                ]
              },
              "sortBy": [
                {
                  "itemKey": "DeviceName",
                  "sortOrder": 1
                }
              ]
            },
            "name": "full-inventory"
          }
        ]
