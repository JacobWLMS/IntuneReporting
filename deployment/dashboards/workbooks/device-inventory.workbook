            "name": "avg-storage-tile"
          },
          {
            "type": 3,
            "content": {
              "version": "KqlItem/1.0",
              "query": "IntuneDevices_CL\r\n| where TimeGenerated {TimeRange}\r\n| summarize arg_max(TimeGenerated, *) by DeviceId\r\n| where '*' in ({OSFilter}) or OperatingSystem in ({OSFilter})\r\n| where '*' in ({ComplianceFilter}) or ComplianceState in ({ComplianceFilter})\r\n| where '*' in ({ManufacturerFilter}) or Manufacturer in ({ManufacturerFilter})\r\n| where isnotnull(FreeStorageGB) and FreeStorageGB > 0\r\n| summarize AvgFree = round(avg(FreeStorageGB), 0)",
              "size": 4,
              "title": "Avg Free (GB)",
              "queryType": 0,
              "resourceType": "microsoft.operationalinsights/workspaces",
              "visualization": "stat",
              "statSettings": {
                "valueColumn": "AvgFree",
                "colorSettings": {
                  "mode": "default",
                  "palette": "green"
                }
              }
            },
            "customWidth": "20",
            "name": "avg-free-tile"
          },
          {
            "type": 3,
            "content": {
              "version": "KqlItem/1.0",
              "query": "IntuneDevices_CL\r\n| where TimeGenerated {TimeRange}\r\n| summarize arg_max(TimeGenerated, *) by DeviceId\r\n| where '*' in ({OSFilter}) or OperatingSystem in ({OSFilter})\r\n| where '*' in ({ComplianceFilter}) or ComplianceState in ({ComplianceFilter})\r\n| where '*' in ({ManufacturerFilter}) or Manufacturer in ({ManufacturerFilter})\r\n| where isnotnull(TotalStorageGB) and TotalStorageGB > 0\r\n| extend UsedPercent = 100.0 * (TotalStorageGB - FreeStorageGB) / TotalStorageGB\r\n| where UsedPercent >= 85\r\n| count",
              "size": 4,
              "title": "High Usage (>85%)",
              "queryType": 0,
              "resourceType": "microsoft.operationalinsights/workspaces",
              "visualization": "stat",
              "statSettings": {
                "valueColumn": "Count",
                "colorSettings": {
                  "mode": "default",
                  "palette": "orange"
                }
              }
            },
            "customWidth": "20",
            "name": "high-usage-tile"
          },
          {
            "type": 3,
            "content": {
              "version": "KqlItem/1.0",
              "query": "IntuneDevices_CL\r\n| where TimeGenerated {TimeRange}\r\n| summarize arg_max(TimeGenerated, *) by DeviceId\r\n| where '*' in ({OSFilter}) or OperatingSystem in ({OSFilter})\r\n| where '*' in ({ComplianceFilter}) or ComplianceState in ({ComplianceFilter})\r\n| where '*' in ({ManufacturerFilter}) or Manufacturer in ({ManufacturerFilter})\r\n| where isnotnull(TotalStorageGB) and TotalStorageGB > 0\r\n| extend UsedPercent = 100.0 * (TotalStorageGB - FreeStorageGB) / TotalStorageGB\r\n| where UsedPercent >= 95\r\n| count",
              "size": 4,
              "title": "Critical (>95%)",
              "queryType": 0,
              "resourceType": "microsoft.operationalinsights/workspaces",
              "visualization": "stat",
              "statSettings": {
                "valueColumn": "Count",
                "colorSettings": {
                  "mode": "default",
                  "palette": "red"
                }
              }
            },
            "customWidth": "20",
            "name": "critical-storage-tile"
          },
          {
            "type": 3,
            "content": {
              "version": "KqlItem/1.0",
              "query": "IntuneDevices_CL\r\n| where TimeGenerated {TimeRange}\r\n| summarize arg_max(TimeGenerated, *) by DeviceId\r\n| where '*' in ({OSFilter}) or OperatingSystem in ({OSFilter})\r\n| where '*' in ({ComplianceFilter}) or ComplianceState in ({ComplianceFilter})\r\n| where '*' in ({ManufacturerFilter}) or Manufacturer in ({ManufacturerFilter})\r\n| where isnotnull(TotalStorageGB) and TotalStorageGB > 0\r\n| count",
              "size": 4,
              "title": "Devices Reporting",
              "queryType": 0,
              "resourceType": "microsoft.operationalinsights/workspaces",
              "visualization": "stat",
              "statSettings": {
                "valueColumn": "Count",
                "colorSettings": {
                  "mode": "default",
                  "palette": "blue"
                }
              }
            },
            "customWidth": "20",
            "name": "storage-devices-tile"
          },
          {
            "type": 3,
            "content": {
              "version": "KqlItem/1.0",
              "query": "IntuneDevices_CL\r\n| where TimeGenerated {TimeRange}\r\n| summarize arg_max(TimeGenerated, *) by DeviceId\r\n| where '*' in ({OSFilter}) or OperatingSystem in ({OSFilter})\r\n| where '*' in ({ComplianceFilter}) or ComplianceState in ({ComplianceFilter})\r\n| where '*' in ({ManufacturerFilter}) or Manufacturer in ({ManufacturerFilter})\r\n| where isnotnull(TotalStorageGB) and TotalStorageGB > 0 and isnotnull(FreeStorageGB)\r\n| extend UsedPercent = round(100.0 * (TotalStorageGB - FreeStorageGB) / TotalStorageGB, 0)\r\n| extend StorageBucket = case(\r\n    UsedPercent < 50, '0-50% Used',\r\n    UsedPercent < 70, '50-70% Used',\r\n    UsedPercent < 85, '70-85% Used',\r\n    UsedPercent < 95, '85-95% Used',\r\n    '>95% Used (Critical)')\r\n| summarize Count = count() by StorageBucket\r\n| order by StorageBucket asc",
              "size": 1,
              "title": "Devices by Storage Usage",
              "queryType": 0,
              "resourceType": "microsoft.operationalinsights/workspaces",
              "visualization": "piechart",
              "chartSettings": {
                "seriesLabelSettings": [
                  {
                    "seriesName": "0-50% Used",
                    "color": "green"
                  },
                  {
                    "seriesName": "50-70% Used",
                    "color": "blue"
                  },
                  {
                    "seriesName": "70-85% Used",
                    "color": "yellow"
                  },
                  {
                    "seriesName": "85-95% Used",
                    "color": "orange"
                  },
                  {
                    "seriesName": ">95% Used (Critical)",
                    "color": "red"
                  }
                ]
              }
            },
            "customWidth": "40",
            "name": "storage-usage-pie"
          },
          {
            "type": 3,
            "content": {
              "version": "KqlItem/1.0",
              "query": "IntuneDevices_CL\r\n| where TimeGenerated {TimeRange}\r\n| summarize arg_max(TimeGenerated, *) by DeviceId\r\n| where '*' in ({OSFilter}) or OperatingSystem in ({OSFilter})\r\n| where '*' in ({ComplianceFilter}) or ComplianceState in ({ComplianceFilter})\r\n| where '*' in ({ManufacturerFilter}) or Manufacturer in ({ManufacturerFilter})\r\n| where isnotnull(TotalStorageGB) and TotalStorageGB > 0\r\n| extend TotalBucket = case(\r\n    TotalStorageGB < 64, '<64 GB',\r\n    TotalStorageGB < 128, '64-127 GB',\r\n    TotalStorageGB < 256, '128-255 GB',\r\n    TotalStorageGB < 512, '256-511 GB',\r\n    TotalStorageGB < 1024, '512-1023 GB',\r\n    '>= 1 TB')\r\n| summarize Count = count() by TotalBucket\r\n| order by TotalBucket asc",
              "size": 0,
              "title": "Devices by Total Storage",
              "queryType": 0,
              "resourceType": "microsoft.operationalinsights/workspaces",
              "visualization": "barchart"
            },
            "customWidth": "60",
            "name": "storage-capacity-bar"
          },
          {
            "type": 1,
            "content": {
              "json": "## Low Storage Devices (>85% Used)\nThese devices may experience performance issues or update failures."
            },
            "name": "low-storage-header"
          },
          {
            "type": 3,
            "content": {
              "version": "KqlItem/1.0",
              "query": "IntuneDevices_CL\r\n| where TimeGenerated {TimeRange}\r\n| summarize arg_max(TimeGenerated, *) by DeviceId\r\n| where '*' in ({OSFilter}) or OperatingSystem in ({OSFilter})\r\n| where '*' in ({ComplianceFilter}) or ComplianceState in ({ComplianceFilter})\r\n| where '*' in ({ManufacturerFilter}) or Manufacturer in ({ManufacturerFilter})\r\n| where isnotnull(TotalStorageGB) and TotalStorageGB > 0 and isnotnull(FreeStorageGB)\r\n| extend UsedPercent = round(100.0 * (TotalStorageGB - FreeStorageGB) / TotalStorageGB, 1)\r\n| where UsedPercent > 85\r\n| project \r\n    DeviceName,\r\n    User = UserDisplayName,\r\n    OS = OperatingSystem,\r\n    ['Total GB'] = round(TotalStorageGB, 1),\r\n    ['Free GB'] = round(FreeStorageGB, 1),\r\n    ['Used %'] = UsedPercent\r\n| order by ['Used %'] desc",
              "size": 0,
              "title": "Devices with Low Storage",
              "queryType": 0,
              "resourceType": "microsoft.operationalinsights/workspaces",
              "visualization": "table",
              "gridSettings": {
                "formatters": [
                  {
                    "columnMatch": "Free GB",
                    "formatter": 8,
                    "formatOptions": {
                      "palette": "redGreen",
                      "min": 0,
                      "max": 50
                    }
                  },
                  {
                    "columnMatch": "Used %",
                    "formatter": 8,
                    "formatOptions": {
                      "palette": "greenRed",
                      "min": 85,
                      "max": 100
                    }
                  }
                ],
                "filter": true
              }
            },
            "name": "low-storage-table"
          }
        ]
      },
      "conditionalVisibility": {
        "parameterName": "Tab",
        "comparison": "isEqualTo",
        "value": "Storage"
      },
      "name": "storage-group"
    },
    {
      "type": 12,
      "content": {
        "version": "NotebookGroup/1.0",
