          },
          {
            "type": 3,
            "content": {
              "version": "KqlItem/1.0",
              "query": "IntuneDevices_CL\r\n| where TimeGenerated {TimeRange}\r\n| summarize arg_max(TimeGenerated, *) by DeviceId\r\n| where '*' in ({OSFilter}) or OperatingSystem in ({OSFilter})\r\n| where '*' in ({ComplianceFilter}) or ComplianceState in ({ComplianceFilter})\r\n| where '*' in ({ManufacturerFilter}) or Manufacturer in ({ManufacturerFilter})\r\n| where isnotempty(UserDisplayName)\r\n| summarize DeviceCount = count() by UserDisplayName\r\n| where DeviceCount >= 3\r\n| count",
              "size": 4,
              "title": "3+ Devices",
              "queryType": 0,
