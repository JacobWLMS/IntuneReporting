{
  "version": "Notebook/1.0",
  "items": [
    {
      "type": 1,
      "content": {
        "json": "# Device Inventory\n\nComprehensive inventory of all managed devices with hardware, software, and enrollment insights."
      },
      "name": "header"
    },
    {
      "type": 9,
      "content": {
        "version": "KqlParameterItem/1.0",
        "parameters": [
          {
            "id": "tab-param",
            "version": "KqlParameterItem/1.0",
            "name": "Tab",
            "type": 1,
            "isRequired": true,
            "isHiddenWhenLocked": true,
            "value": "Overview"
          },
          {
            "id": "time-range",
            "version": "KqlParameterItem/1.0",
            "name": "TimeRange",
            "type": 4,
            "isRequired": true,
            "typeSettings": {
              "selectableValues": [
                {
                  "durationMs": 86400000
                },
                {
                  "durationMs": 604800000
                },
                {
                  "durationMs": 2592000000
                }
              ],
              "allowCustom": true
            },
            "label": "Time Range",
            "value": {
              "durationMs": 604800000
            }
          },
          {
            "id": "os-filter",
            "version": "KqlParameterItem/1.0",
            "name": "OSFilter",
            "type": 2,
            "isRequired": true,
            "multiSelect": true,
            "quote": "'",
            "delimiter": ",",
            "query": "IntuneDevices_CL\r\n| where TimeGenerated > ago(30d)\r\n| summarize arg_max(TimeGenerated, *) by DeviceId\r\n| distinct OperatingSystem\r\n| where isnotempty(OperatingSystem)\r\n| order by OperatingSystem asc",
            "typeSettings": {
              "additionalResourceOptions": [
                "value::all"
              ],
              "showDefault": false
            },
            "defaultValue": "value::all",
            "queryType": 0,
            "resourceType": "microsoft.operationalinsights/workspaces",
            "label": "Operating System",
            "value": [
              "value::all"
            ]
          },
          {
            "id": "compliance-filter",
            "version": "KqlParameterItem/1.0",
            "name": "ComplianceFilter",
            "type": 2,
            "isRequired": true,
            "multiSelect": true,
            "quote": "'",
            "delimiter": ",",
            "query": "IntuneDevices_CL\r\n| where TimeGenerated > ago(30d)\r\n| summarize arg_max(TimeGenerated, *) by DeviceId\r\n| distinct ComplianceState\r\n| where isnotempty(ComplianceState)\r\n| order by ComplianceState asc",
            "typeSettings": {
              "additionalResourceOptions": [
                "value::all"
              ],
              "showDefault": false
            },
            "defaultValue": "value::all",
            "queryType": 0,
            "resourceType": "microsoft.operationalinsights/workspaces",
            "label": "Compliance",
            "value": [
              "value::all"
            ]
          },
          {
            "id": "manufacturer-filter",
            "version": "KqlParameterItem/1.0",
            "name": "ManufacturerFilter",
            "type": 2,
            "isRequired": true,
            "multiSelect": true,
            "quote": "'",
            "delimiter": ",",
            "query": "IntuneDevices_CL\r\n| where TimeGenerated > ago(30d)\r\n| summarize arg_max(TimeGenerated, *) by DeviceId\r\n| distinct Manufacturer\r\n| where isnotempty(Manufacturer)\r\n| order by Manufacturer asc",
            "typeSettings": {
              "additionalResourceOptions": [
                "value::all"
              ],
              "showDefault": false
            },
            "defaultValue": "value::all",
            "queryType": 0,
            "resourceType": "microsoft.operationalinsights/workspaces",
            "label": "Manufacturer",
            "value": [
              "value::all"
            ]
          }
        ],
        "style": "pills",
        "queryType": 0,
        "resourceType": "microsoft.operationalinsights/workspaces"
      },
      "name": "parameters"
    },
    {
      "type": 11,
      "content": {
        "version": "LinkItem/1.0",
        "style": "tabs",
        "links": [
          {
            "id": "overview-tab",
            "cellValue": "Tab",
            "linkTarget": "parameter",
            "linkLabel": "Overview",
            "subTarget": "Overview",
            "style": "link"
          },
          {
            "id": "hardware-tab",
            "cellValue": "Tab",
            "linkTarget": "parameter",
            "linkLabel": "Hardware",
            "subTarget": "Hardware",
            "style": "link"
          },
          {
            "id": "os-tab",
            "cellValue": "Tab",
            "linkTarget": "parameter",
            "linkLabel": "OS Analysis",
            "subTarget": "OSAnalysis",
            "style": "link"
          },
          {
            "id": "storage-tab",
            "cellValue": "Tab",
            "linkTarget": "parameter",
            "linkLabel": "Storage",
            "subTarget": "Storage",
            "style": "link"
          },
          {
            "id": "users-tab",
            "cellValue": "Tab",
            "linkTarget": "parameter",
            "linkLabel": "Users",
            "subTarget": "Users",
            "style": "link"
          },
          {
            "id": "inventory-tab",
            "cellValue": "Tab",
            "linkTarget": "parameter",
            "linkLabel": "Full Inventory",
            "subTarget": "Inventory",
            "style": "link"
          }
        ]
      },
      "name": "tabs"
    },
    {
      "type": 12,
      "content": {
        "version": "NotebookGroup/1.0",
        "groupType": "editable",
        "items": [
          {
            "type": 3,
            "content": {
              "version": "KqlItem/1.0",
              "query": "IntuneDevices_CL\r\n| where TimeGenerated {TimeRange}\r\n| summarize arg_max(TimeGenerated, *) by DeviceId\r\n| where '*' in ({OSFilter}) or OperatingSystem in ({OSFilter})\r\n| where '*' in ({ComplianceFilter}) or ComplianceState in ({ComplianceFilter})\r\n| where '*' in ({ManufacturerFilter}) or Manufacturer in ({ManufacturerFilter})\r\n| count",
              "size": 4,
              "title": "Total Devices",
              "queryType": 0,
              "resourceType": "microsoft.operationalinsights/workspaces",
              "visualization": "stat",
              "statSettings": {
                "valueColumn": "Count",
                "colorSettings": {
                  "mode": "default",
                  "palette": "blue"
                }
              }
            },
            "customWidth": "20",
            "name": "total-devices"
          },
          {
            "type": 3,
            "content": {
              "version": "KqlItem/1.0",
              "query": "IntuneDevices_CL\r\n| where TimeGenerated {TimeRange}\r\n| summarize arg_max(TimeGenerated, *) by DeviceId\r\n| where '*' in ({OSFilter}) or OperatingSystem in ({OSFilter})\r\n| where '*' in ({ComplianceFilter}) or ComplianceState in ({ComplianceFilter})\r\n| where '*' in ({ManufacturerFilter}) or Manufacturer in ({ManufacturerFilter})\r\n| where ComplianceState == 'compliant'\r\n| count",
              "size": 4,
              "title": "Compliant",
              "queryType": 0,
              "resourceType": "microsoft.operationalinsights/workspaces",
              "visualization": "stat",
              "statSettings": {
                "valueColumn": "Count",
                "colorSettings": {
                  "mode": "default",
                  "palette": "green"
                }
              }
            },
            "customWidth": "20",
            "name": "compliant-count"
          },
          {
            "type": 3,
            "content": {
              "version": "KqlItem/1.0",
              "query": "IntuneDevices_CL\r\n| where TimeGenerated {TimeRange}\r\n| summarize arg_max(TimeGenerated, *) by DeviceId\r\n| where '*' in ({OSFilter}) or OperatingSystem in ({OSFilter})\r\n| where '*' in ({ComplianceFilter}) or ComplianceState in ({ComplianceFilter})\r\n| where '*' in ({ManufacturerFilter}) or Manufacturer in ({ManufacturerFilter})\r\n| where ComplianceState == 'noncompliant'\r\n| count",
              "size": 4,
              "title": "Non-Compliant",
              "queryType": 0,
              "resourceType": "microsoft.operationalinsights/workspaces",
              "visualization": "stat",
              "statSettings": {
                "valueColumn": "Count",
                "colorSettings": {
                  "mode": "default",
                  "palette": "red"
                }
              }
            },
            "customWidth": "20",
            "name": "noncompliant-count"
          },
          {
            "type": 3,
            "content": {
              "version": "KqlItem/1.0",
              "query": "IntuneDevices_CL\r\n| where TimeGenerated {TimeRange}\r\n| summarize arg_max(TimeGenerated, *) by DeviceId\r\n| where '*' in ({OSFilter}) or OperatingSystem in ({OSFilter})\r\n| where '*' in ({ComplianceFilter}) or ComplianceState in ({ComplianceFilter})\r\n| where '*' in ({ManufacturerFilter}) or Manufacturer in ({ManufacturerFilter})\r\n| where IsEncrypted == true\r\n| count",
              "size": 4,
              "title": "Encrypted",
              "queryType": 0,
              "resourceType": "microsoft.operationalinsights/workspaces",
              "visualization": "stat",
              "statSettings": {
                "valueColumn": "Count",
                "colorSettings": {
                  "mode": "default",
                  "palette": "green"
                }
              }
            },
            "customWidth": "20",
            "name": "encrypted-count"
          },
          {
            "type": 3,
            "content": {
              "version": "KqlItem/1.0",
              "query": "IntuneDevices_CL\r\n| where TimeGenerated {TimeRange}\r\n| summarize arg_max(TimeGenerated, *) by DeviceId\r\n| where '*' in ({OSFilter}) or OperatingSystem in ({OSFilter})\r\n| where '*' in ({ComplianceFilter}) or ComplianceState in ({ComplianceFilter})\r\n| where '*' in ({ManufacturerFilter}) or Manufacturer in ({ManufacturerFilter})\r\n| where OwnerType == 'company'\r\n| count",
              "size": 4,
              "title": "Corporate",
              "queryType": 0,
              "resourceType": "microsoft.operationalinsights/workspaces",
              "visualization": "stat",
              "statSettings": {
                "valueColumn": "Count",
                "colorSettings": {
                  "mode": "default",
                  "palette": "blue"
                }
              }
            },
            "customWidth": "20",
            "name": "corporate-count"
          },
          {
            "type": 3,
            "content": {
              "version": "KqlItem/1.0",
              "query": "IntuneDevices_CL\r\n| where TimeGenerated {TimeRange}\r\n| summarize arg_max(TimeGenerated, *) by DeviceId\r\n| where '*' in ({OSFilter}) or OperatingSystem in ({OSFilter})\r\n| where '*' in ({ComplianceFilter}) or ComplianceState in ({ComplianceFilter})\r\n| where '*' in ({ManufacturerFilter}) or Manufacturer in ({ManufacturerFilter})\r\n| where OwnerType == 'personal'\r\n| count",
              "size": 4,
              "title": "Personal (BYOD)",
              "queryType": 0,
              "resourceType": "microsoft.operationalinsights/workspaces",
              "visualization": "stat",
              "statSettings": {
                "valueColumn": "Count",
                "colorSettings": {
                  "mode": "default",
                  "palette": "purple"
                }
              }
            },
            "customWidth": "20",
            "name": "byod-count"
          },
          {
            "type": 3,
            "content": {
              "version": "KqlItem/1.0",
              "query": "IntuneDevices_CL\r\n| where TimeGenerated {TimeRange}\r\n| summarize arg_max(TimeGenerated, *) by DeviceId\r\n| where '*' in ({OSFilter}) or OperatingSystem in ({OSFilter})\r\n| where '*' in ({ComplianceFilter}) or ComplianceState in ({ComplianceFilter})\r\n| where '*' in ({ManufacturerFilter}) or Manufacturer in ({ManufacturerFilter})\r\n| summarize Count = count() by OperatingSystem\r\n| order by Count desc",
              "size": 1,
              "title": "By Operating System",
              "queryType": 0,
              "resourceType": "microsoft.operationalinsights/workspaces",
              "visualization": "piechart"
            },
            "customWidth": "25",
            "name": "os-pie"
          },
          {
            "type": 3,
            "content": {
              "version": "KqlItem/1.0",
              "query": "IntuneDevices_CL\r\n| where TimeGenerated {TimeRange}\r\n| summarize arg_max(TimeGenerated, *) by DeviceId\r\n| where '*' in ({OSFilter}) or OperatingSystem in ({OSFilter})\r\n| where '*' in ({ComplianceFilter}) or ComplianceState in ({ComplianceFilter})\r\n| where '*' in ({ManufacturerFilter}) or Manufacturer in ({ManufacturerFilter})\r\n| summarize Count = count() by ComplianceState\r\n| order by Count desc",
              "size": 1,
              "title": "By Compliance State",
              "queryType": 0,
              "resourceType": "microsoft.operationalinsights/workspaces",
              "visualization": "piechart",
              "chartSettings": {
                "seriesLabelSettings": [
                  {
                    "seriesName": "compliant",
                    "color": "green"
                  },
                  {
                    "seriesName": "noncompliant",
                    "color": "red"
                  },
                  {
                    "seriesName": "unknown",
                    "color": "gray"
                  },
                  {
                    "seriesName": "inGracePeriod",
                    "color": "yellow"
                  }
                ]
              }
            },
            "customWidth": "25",
            "name": "compliance-pie"
          },
          {
            "type": 3,
            "content": {
              "version": "KqlItem/1.0",
              "query": "IntuneDevices_CL\r\n| where TimeGenerated {TimeRange}\r\n| summarize arg_max(TimeGenerated, *) by DeviceId\r\n| where '*' in ({OSFilter}) or OperatingSystem in ({OSFilter})\r\n| where '*' in ({ComplianceFilter}) or ComplianceState in ({ComplianceFilter})\r\n| where '*' in ({ManufacturerFilter}) or Manufacturer in ({ManufacturerFilter})\r\n| summarize Count = count() by Manufacturer\r\n| top 10 by Count desc",
              "size": 1,
              "title": "Top 10 Manufacturers",
              "queryType": 0,
              "resourceType": "microsoft.operationalinsights/workspaces",
              "visualization": "barchart"
            },
            "customWidth": "25",
            "name": "manufacturer-bar"
          },
          {
            "type": 3,
            "content": {
              "version": "KqlItem/1.0",
              "query": "IntuneDevices_CL\r\n| where TimeGenerated {TimeRange}\r\n| summarize arg_max(TimeGenerated, *) by DeviceId\r\n| where '*' in ({OSFilter}) or OperatingSystem in ({OSFilter})\r\n| where '*' in ({ComplianceFilter}) or ComplianceState in ({ComplianceFilter})\r\n| where '*' in ({ManufacturerFilter}) or Manufacturer in ({ManufacturerFilter})\r\n| summarize Count = count() by OwnerType\r\n| order by Count desc",
              "size": 1,
              "title": "By Ownership",
              "queryType": 0,
              "resourceType": "microsoft.operationalinsights/workspaces",
              "visualization": "piechart",
              "chartSettings": {
                "seriesLabelSettings": [
                  {
                    "seriesName": "company",
                    "label": "Corporate",
                    "color": "blue"
                  },
                  {
                    "seriesName": "personal",
                    "label": "Personal (BYOD)",
                    "color": "purple"
                  }
                ]
              }
            },
            "customWidth": "25",
            "name": "ownership-pie"
          },
          {
            "type": 3,
            "content": {
              "version": "KqlItem/1.0",
              "query": "IntuneDevices_CL\r\n| where TimeGenerated {TimeRange}\r\n| summarize arg_max(TimeGenerated, *) by DeviceId\r\n| where '*' in ({OSFilter}) or OperatingSystem in ({OSFilter})\r\n| where '*' in ({ComplianceFilter}) or ComplianceState in ({ComplianceFilter})\r\n| where '*' in ({ManufacturerFilter}) or Manufacturer in ({ManufacturerFilter})\r\n| summarize Count = count() by bin(EnrolledDateTime, 1d)\r\n| order by EnrolledDateTime asc",
              "size": 0,
              "title": "Device Enrollments Over Time",
              "color": "grayBlue",
              "queryType": 0,
              "resourceType": "microsoft.operationalinsights/workspaces",
              "visualization": "linechart"
            },
            "name": "enrollment-trend"
          }
        ]
      },
      "conditionalVisibility": {
        "parameterName": "Tab",
        "comparison": "isEqualTo",
        "value": "Overview"
      },
      "name": "overview-group"
    },
    {
      "type": 12,
      "content": {
        "version": "NotebookGroup/1.0",
        "groupType": "editable",
        "items": [
          {
            "type": 3,
            "content": {
              "version": "KqlItem/1.0",
              "query": "IntuneDevices_CL\r\n| where TimeGenerated {TimeRange}\r\n| summarize arg_max(TimeGenerated, *) by DeviceId\r\n| where '*' in ({OSFilter}) or OperatingSystem in ({OSFilter})\r\n| where '*' in ({ComplianceFilter}) or ComplianceState in ({ComplianceFilter})\r\n| where '*' in ({ManufacturerFilter}) or Manufacturer in ({ManufacturerFilter})\r\n| extend EnrollmentAge = datetime_diff('month', now(), EnrolledDateTime)\r\n| extend AgeBucket = case(\r\n    EnrollmentAge <= 3, '0-3 months',\r\n    EnrollmentAge <= 6, '3-6 months',\r\n    EnrollmentAge <= 12, '6-12 months',\r\n    EnrollmentAge <= 24, '1-2 years',\r\n    EnrollmentAge <= 36, '2-3 years',\r\n    '>3 years')\r\n| summarize Count = count() by AgeBucket\r\n| order by AgeBucket asc",
              "size": 1,
              "title": "Devices by Enrollment Age",
              "queryType": 0,
              "resourceType": "microsoft.operationalinsights/workspaces",
              "visualization": "piechart",
              "chartSettings": {
                "seriesLabelSettings": [
                  {
                    "seriesName": "0-3 months",
                    "color": "green"
                  },
                  {
                    "seriesName": "3-6 months",
                    "color": "blue"
                  },
                  {
                    "seriesName": "6-12 months",
                    "color": "yellow"
                  },
                  {
                    "seriesName": "1-2 years",
                    "color": "orange"
                  },
                  {
                    "seriesName": "2-3 years",
                    "color": "redOrange"
                  },
                  {
                    "seriesName": ">3 years",
                    "color": "red"
                  }
                ]
              }
            },
            "customWidth": "40",
            "name": "age-pie"
          },
          {
            "type": 3,
            "content": {
              "version": "KqlItem/1.0",
              "query": "IntuneDevices_CL\r\n| where TimeGenerated {TimeRange}\r\n| summarize arg_max(TimeGenerated, *) by DeviceId\r\n| where '*' in ({OSFilter}) or OperatingSystem in ({OSFilter})\r\n| where '*' in ({ComplianceFilter}) or ComplianceState in ({ComplianceFilter})\r\n| where '*' in ({ManufacturerFilter}) or Manufacturer in ({ManufacturerFilter})\r\n| extend EnrollmentAge = datetime_diff('month', now(), EnrolledDateTime)\r\n| extend AgeBucket = case(\r\n    EnrollmentAge <= 3, '0-3 months',\r\n    EnrollmentAge <= 6, '3-6 months',\r\n    EnrollmentAge <= 12, '6-12 months',\r\n    EnrollmentAge <= 24, '1-2 years',\r\n    EnrollmentAge <= 36, '2-3 years',\r\n    '>3 years')\r\n| summarize Count = count() by OperatingSystem, AgeBucket\r\n| order by OperatingSystem asc",
              "size": 0,
              "title": "Age by Operating System",
              "queryType": 0,
              "resourceType": "microsoft.operationalinsights/workspaces",
              "visualization": "barchart",
              "chartSettings": {
                "xAxis": "OperatingSystem",
                "group": "AgeBucket",
                "createOtherGroup": false
              }
            },
            "customWidth": "60",
            "name": "age-by-os"
          },
          {
            "type": 1,
            "content": {
              "json": "### Manufacturer & Model Breakdown"
            },
            "name": "hardware-header"
          },
          {
            "type": 3,
            "content": {
              "version": "KqlItem/1.0",
              "query": "IntuneDevices_CL\r\n| where TimeGenerated {TimeRange}\r\n| summarize arg_max(TimeGenerated, *) by DeviceId\r\n| where '*' in ({OSFilter}) or OperatingSystem in ({OSFilter})\r\n| where '*' in ({ComplianceFilter}) or ComplianceState in ({ComplianceFilter})\r\n| where '*' in ({ManufacturerFilter}) or Manufacturer in ({ManufacturerFilter})\r\n| summarize \r\n    Count = count(),\r\n    Compliant = countif(ComplianceState == 'compliant'),\r\n    Encrypted = countif(IsEncrypted == true)\r\n  by Manufacturer\r\n| extend ComplianceRate = round(100.0 * Compliant / Count, 1)\r\n| extend EncryptionRate = round(100.0 * Encrypted / Count, 1)\r\n| order by Count desc",
              "size": 0,
              "title": "Devices by Manufacturer",
              "queryType": 0,
              "resourceType": "microsoft.operationalinsights/workspaces",
              "visualization": "table",
              "gridSettings": {
                "formatters": [
                  {
                    "columnMatch": "Count",
                    "formatter": 4,
                    "formatOptions": {
                      "palette": "blue"
                    }
                  },
                  {
                    "columnMatch": "ComplianceRate",
                    "formatter": 8,
                    "formatOptions": {
                      "palette": "redGreen",
                      "min": 0,
                      "max": 100
                    }
                  },
                  {
                    "columnMatch": "EncryptionRate",
                    "formatter": 8,
                    "formatOptions": {
                      "palette": "redGreen",
                      "min": 0,
                      "max": 100
                    }
                  }
                ],
                "filter": true
              }
            },
            "name": "by-manufacturer"
          },
          {
            "type": 3,
            "content": {
              "version": "KqlItem/1.0",
              "query": "IntuneDevices_CL\r\n| where TimeGenerated {TimeRange}\r\n| summarize arg_max(TimeGenerated, *) by DeviceId\r\n| where '*' in ({OSFilter}) or OperatingSystem in ({OSFilter})\r\n| where '*' in ({ComplianceFilter}) or ComplianceState in ({ComplianceFilter})\r\n| where '*' in ({ManufacturerFilter}) or Manufacturer in ({ManufacturerFilter})\r\n| summarize \r\n    Count = count(),\r\n    Compliant = countif(ComplianceState == 'compliant'),\r\n    AvgStorageGB = round(avg(TotalStorageGB), 1)\r\n  by Manufacturer, Model\r\n| extend ComplianceRate = round(100.0 * Compliant / Count, 1)\r\n| order by Count desc\r\n| take 25",
              "size": 0,
              "title": "Top 25 Device Models",
              "queryType": 0,
              "resourceType": "microsoft.operationalinsights/workspaces",
              "visualization": "table",
              "gridSettings": {
                "formatters": [
                  {
                    "columnMatch": "Count",
                    "formatter": 4,
                    "formatOptions": {
                      "palette": "blue"
                    }
                  },
                  {
                    "columnMatch": "ComplianceRate",
                    "formatter": 8,
                    "formatOptions": {
                      "palette": "redGreen",
                      "min": 0,
                      "max": 100
                    }
                  }
                ],
                "filter": true
              }
            },
            "name": "top-models"
          }
        ]
      },
      "conditionalVisibility": {
        "parameterName": "Tab",
        "comparison": "isEqualTo",
        "value": "Hardware"
      },
      "name": "hardware-group"
    },
    {
      "type": 12,
      "content": {
        "version": "NotebookGroup/1.0",
        "groupType": "editable",
        "items": [
          {
            "type": 3,
            "content": {
              "version": "KqlItem/1.0",
              "query": "IntuneDevices_CL\r\n| where TimeGenerated {TimeRange}\r\n| summarize arg_max(TimeGenerated, *) by DeviceId\r\n| where '*' in ({OSFilter}) or OperatingSystem in ({OSFilter})\r\n| where '*' in ({ComplianceFilter}) or ComplianceState in ({ComplianceFilter})\r\n| where '*' in ({ManufacturerFilter}) or Manufacturer in ({ManufacturerFilter})\r\n| summarize Count = count() by OperatingSystem\r\n| order by Count desc",
              "size": 0,
              "title": "Devices by OS",
              "queryType": 0,
              "resourceType": "microsoft.operationalinsights/workspaces",
              "visualization": "barchart"
            },
            "customWidth": "50",
            "name": "os-bar"
          },
          {
            "type": 3,
            "content": {
              "version": "KqlItem/1.0",
              "query": "IntuneDevices_CL\r\n| where TimeGenerated {TimeRange}\r\n| summarize arg_max(TimeGenerated, *) by DeviceId\r\n| where '*' in ({OSFilter}) or OperatingSystem in ({OSFilter})\r\n| where '*' in ({ComplianceFilter}) or ComplianceState in ({ComplianceFilter})\r\n| where '*' in ({ManufacturerFilter}) or Manufacturer in ({ManufacturerFilter})\r\n| summarize \r\n    Total = count(),\r\n    Compliant = countif(ComplianceState == 'compliant'),\r\n    NonCompliant = countif(ComplianceState == 'noncompliant'),\r\n    Encrypted = countif(IsEncrypted == true)\r\n  by OperatingSystem\r\n| extend ComplianceRate = round(100.0 * Compliant / Total, 1)\r\n| extend EncryptionRate = round(100.0 * Encrypted / Total, 1)\r\n| order by Total desc",
              "size": 0,
              "title": "OS Summary",
              "queryType": 0,
              "resourceType": "microsoft.operationalinsights/workspaces",
              "visualization": "table",
              "gridSettings": {
                "formatters": [
                  {
                    "columnMatch": "Total",
                    "formatter": 4,
                    "formatOptions": {
                      "palette": "blue"
                    }
                  },
                  {
                    "columnMatch": "Compliant",
                    "formatter": 4,
                    "formatOptions": {
                      "palette": "green"
                    }
                  },
                  {
                    "columnMatch": "NonCompliant",
                    "formatter": 4,
                    "formatOptions": {
                      "palette": "red"
                    }
                  },
                  {
